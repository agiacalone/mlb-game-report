#!/usr/bin/env python3
"""Generate a newspaper-style Markdown game report from the MLB Stats API.

Thin orchestrator over ``mlb-fetch`` (API → CSV dataset) and ``mlb-render``
(CSV dataset → Markdown/HTML). Preserves the pre-refactor CLI.
"""
from __future__ import annotations

import argparse
import subprocess
import sys
import zipfile
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _shared import LIBRARY, rebuild_index, render_html, render_markdown, slugify  # noqa: E402

# Reuse the in-process fetch + render helpers to avoid an extra subprocess.
import importlib.util
from importlib.machinery import SourceFileLoader


def _load(name: str, path: Path):
    loader = SourceFileLoader(name, str(path))
    spec = importlib.util.spec_from_loader(name, loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


_HERE = Path(__file__).resolve().parent
_FETCH = _load("mlb_fetch", _HERE / "mlb-fetch")


def _dataset_slug(ds: dict) -> str:
    g = ds["game"]
    return f"{g['date']}-{slugify(g['away_team_short'])}-at-{slugify(g['home_team_short'])}"


def _zip_bundle(zip_path: Path, dataset_dir: Path, md_path: Path, html_path: Path | None) -> None:
    with zipfile.ZipFile(zip_path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        base = dataset_dir.name
        for p in sorted(dataset_dir.rglob("*")):
            if p.is_file():
                zf.write(p, arcname=f"{base}/{p.relative_to(dataset_dir)}")
        if md_path.exists():
            zf.write(md_path, arcname=md_path.name)
        if html_path and html_path.exists():
            zf.write(html_path, arcname=html_path.name)


def main() -> None:
    ap = argparse.ArgumentParser(description="Generate a newspaper-style MLB game briefing.")
    ap.add_argument("gamePk", nargs="?", type=int, help="MLB gamePk")
    ap.add_argument("--team", help="Team ID or abbreviation (use with --date)")
    ap.add_argument("--date", help="Game date YYYY-MM-DD (use with --team)")
    ap.add_argument("-o", "--output", help="Output .md file (default: ~/games-attended/<slug>.md)")
    ap.add_argument("--stdout", action="store_true", help="Print to stdout instead of writing files")
    g = ap.add_argument_group("attended-game metadata")
    g.add_argument("--attended", action="store_true")
    g.add_argument("--section")
    g.add_argument("--row")
    g.add_argument("--seat")
    g.add_argument("--with", dest="companions")
    g.add_argument("--no-index", action="store_true")
    ap.add_argument("--html", action="store_true",
                    help="Also render a sibling .html via pandoc + newspaper stylesheet")
    ap.add_argument("--open", action="store_true",
                    help="Open the generated HTML in the browser (implies --html)")
    ap.add_argument("--zip", dest="do_zip", action="store_true",
                    help="Bundle the dataset dir + .md + .html into <slug>.zip next to the other outputs")
    args = ap.parse_args()

    if args.gamePk:
        pk = args.gamePk
    elif args.team and args.date:
        pk = _FETCH.find_game(_FETCH.resolve_team(args.team), args.date)
    else:
        ap.error("Provide a gamePk or both --team and --date")

    attended_meta = {
        "attended": args.attended,
        "section": args.section,
        "row": args.row,
        "seat": args.seat,
        "companions": args.companions,
    }
    dataset = _FETCH.build_dataset(pk, attended_meta)
    slug = _dataset_slug(dataset)

    # --- stdout shortcut: no files at all ---
    if args.stdout:
        md, _ = render_markdown(dataset)
        sys.stdout.write(md)
        return

    # --- pick output location; also choose dataset dir as a sibling ---
    if args.output:
        md_path = Path(args.output)
        library = md_path.parent
    else:
        library = LIBRARY
        md_path = library / f"{slug}.md"
    library.mkdir(parents=True, exist_ok=True)

    dataset_dir = library / slug
    _FETCH.write_dataset(dataset_dir, dataset)

    md, _ = render_markdown(dataset)
    md_path.write_text(md)
    print(f"Wrote {md_path}", file=sys.stderr)
    print(f"Dataset at {dataset_dir}", file=sys.stderr)

    html_path = None
    if args.html or args.open or args.do_zip:
        g = dataset["game"]
        body_class_parts = []
        if g.get("away_abbr"):
            body_class_parts.append(f"away-{g['away_abbr']}")
        if g.get("home_abbr"):
            body_class_parts.append(f"home-{g['home_abbr']}")
        body_class = " ".join(body_class_parts)
        html_path = render_html(md_path, body_class=body_class)
        if html_path:
            print(f"Rendered {html_path}", file=sys.stderr)

    if args.do_zip:
        zip_path = library / f"{slug}.zip"
        _zip_bundle(zip_path, dataset_dir, md_path, html_path)
        print(f"Bundled {zip_path}", file=sys.stderr)

    if not args.no_index and md_path.parent == LIBRARY:
        rebuild_index(LIBRARY)
        print(f"Updated {LIBRARY / 'INDEX.md'}", file=sys.stderr)

    if args.open and html_path:
        subprocess.run(["open", str(html_path)])


if __name__ == "__main__":
    main()
